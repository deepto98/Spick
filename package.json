{
  "name": "spick-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "A macOS-first foundation for fast, multilingual desktop dictation.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:input-method": "SPICK_INPUT_SIGNING_MODE=check ./scripts/build-input-method.sh",
    "build:input-method:development": "SPICK_INPUT_SIGNING_MODE=development ./scripts/build-input-method.sh",
    "build:input-method:release": "SPICK_INPUT_SIGNING_MODE=release ./scripts/build-input-method.sh",
    "build:input-method:unsafe-adhoc": "SPICK_INPUT_SIGNING_MODE=unsafe-adhoc SPICK_INPUT_ALLOW_UNSAFE_ADHOC_BUILD=YES ./scripts/build-input-method.sh",
    "build:desktop:input-method:development": "./scripts/build-input-method-desktop.sh development",
    "build:desktop:input-method:unsafe-adhoc": "SPICK_INPUT_ALLOW_UNSAFE_ADHOC_BUILD=YES ./scripts/build-input-method-desktop.sh unsafe-adhoc",
    "build:desktop:input-method:compatibility:development": "./scripts/build-input-method-desktop.sh development compatibility",
    "build:desktop:input-method:compatibility:unsafe-adhoc": "SPICK_INPUT_ALLOW_UNSAFE_ADHOC_BUILD=YES ./scripts/build-input-method-desktop.sh unsafe-adhoc compatibility",
    "build:macos:local": "./scripts/build-macos.sh local",
    "build:macos:release": "./scripts/build-macos.sh release",
    "check:input-method": "./scripts/check-input-method.sh",
    "preflight:input-method:compatibility": "./scripts/preflight-input-method-compatibility.sh",
    "run:input-method:compatibility": "./scripts/run-input-method-compatibility.sh",
    "check": "npm run format:check && npm run lint && npm run test && npm run build",
    "check:all": "npm run check && npm run check:native",
    "check:native": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo test --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo check --manifest-path src-tauri/Cargo.toml",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "lucide-react": "^1.25.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
